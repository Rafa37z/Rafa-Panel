--[[
    ========== HEALTH BAR ==========
]]
local healthBarActive = false

local function cleanupHealthBars()
    for targetPlayer, data in pairs(healthBars) do
        if data then
            if data.Bill then pcall(function() data.Bill:Destroy() end) end
            if data.Connection then pcall(function() data.Connection:Disconnect() end) end
        end
    end
    healthBars = {}
end

local function createHealthBarForPlayer(targetPlayer)
    if targetPlayer == player then return end
    
    if healthBars[targetPlayer] and healthBars[targetPlayer].Bill and healthBars[targetPlayer].Bill.Parent then
        return
    end
    
    local character = targetPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    local success, billboard = pcall(function()
        local bill = Instance.new("BillboardGui")
        bill.Name = "HealthBar_"..targetPlayer.Name
        bill.Size = UDim2.new(0, 50, 0, 14)
        bill.StudsOffset = Vector3.new(0, 2.5, 0)
        bill.AlwaysOnTop = true
        bill.ClipsDescendants = true
        bill.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        bill.ResetOnSpawn = false
        bill.Active = true
        bill.Parent = character
        
        local background = Instance.new("Frame")
        background.Name = "Background"
        background.Size = UDim2.new(1, 0, 1, 0)
        background.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        background.BackgroundTransparency = 0.3
        background.BorderSizePixel = 0
        background.ZIndex = 2
        background.Parent = bill
        
        local bgCorner = Instance.new("UICorner")
        bgCorner.CornerRadius = UDim.new(0, 3)
        bgCorner.Parent = background
        
        local healthBar = Instance.new("Frame")
        healthBar.Name = "HealthFill"
        healthBar.Size = UDim2.new(humanoid.Health / humanoid.MaxHealth, 0, 1, 0)
        healthBar.BackgroundColor3 = Colors.HealthGreen
        healthBar.BorderSizePixel = 0
        healthBar.ZIndex = 3
        healthBar.Parent = background
        
        local healthCorner = Instance.new("UICorner")
        healthCorner.CornerRadius = UDim.new(0, 3)
        healthCorner.Parent = healthBar
        
        local healthText = Instance.new("TextLabel")
        healthText.Name = "HealthText"
        healthText.Size = UDim2.new(1, 0, 1, 0)
        healthText.BackgroundTransparency = 1
        healthText.Text = math.floor(humanoid.Health) .. "/" .. math.floor(humanoid.MaxHealth)
        healthText.TextColor3 = Colors.Text
        healthText.Font = Enum.Font.GothamBold
        healthText.TextSize = 9
        healthText.TextScaled = false
        healthText.ZIndex = 4
        healthText.Parent = background
        
        return bill
    end)
    
    if success then
        healthBars[targetPlayer] = {
            Bill = billboard,
            Humanoid = humanoid
        }
        
        local connection
        connection = humanoid.HealthChanged:Connect(function()
            if not healthBarActive then
                if connection then pcall(function() connection:Disconnect() end) end
                return
            end
            
            local data = healthBars[targetPlayer]
            if not data or not data.Bill or not data.Bill.Parent then
                if connection then pcall(function() connection:Disconnect() end) end
                healthBars[targetPlayer] = nil
                return
            end
            
            pcall(function()
                local bill = data.Bill
                local background = bill:FindFirstChild("Background")
                if background then
                    local healthBar = background:FindFirstChild("HealthFill")
                    local healthText = background:FindFirstChild("HealthText")
                    
                    if healthBar and healthText then
                        local percent = humanoid.Health / humanoid.MaxHealth
                        healthBar.Size = UDim2.new(percent, 0, 1, 0)
                        healthText.Text = math.floor(humanoid.Health) .. "/" .. math.floor(humanoid.MaxHealth)
                        
                        if percent > 0.6 then
                            healthBar.BackgroundColor3 = Colors.HealthGreen
                        elseif percent > 0.3 then
                            healthBar.BackgroundColor3 = Colors.HealthYellow
                        else
                            healthBar.BackgroundColor3 = Colors.HealthRed
                        end
                    end
                end
            end)
        end)
        
        healthBars[targetPlayer].Connection = connection
    end
end

local function toggleHealthBar(state)
    healthBarActive = state
    
    if Toggles.healthBar then
        Toggles.healthBar.setState(state)
    end
    
    if state then
        cleanupHealthBars()
        
        for _, otherPlayer in ipairs(Players:GetPlayers()) do
            if otherPlayer ~= player then
                task.spawn(function() createHealthBarForPlayer(otherPlayer) end)
            end
        end
        
        Players.PlayerAdded:Connect(function(newPlayer)
            if healthBarActive and newPlayer ~= player then
                newPlayer.CharacterAdded:Connect(function()
                    task.wait(1)
                    if healthBarActive then createHealthBarForPlayer(newPlayer) end
                end)
                if newPlayer.Character then
                    task.wait(1)
                    if healthBarActive then createHealthBarForPlayer(newPlayer) end
                end
            end
        end)
        
        Players.PlayerRemoving:Connect(function(leavingPlayer)
            if healthBars[leavingPlayer] then
                if healthBars[leavingPlayer].Bill then pcall(function() healthBars[leavingPlayer].Bill:Destroy() end) end
                if healthBars[leavingPlayer].Connection then pcall(function() healthBars[leavingPlayer].Connection:Disconnect() end) end
                healthBars[leavingPlayer] = nil
            end
        end)
        
        createNotification("Health Bar", "Ativado", "success")
