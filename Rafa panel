]]
local function cleanupESP()
    for targetPlayer, highlight in pairs(espHighlights) do
        if highlight then pcall(function() highlight:Destroy() end) end
    end
    espHighlights = {}
end

local function createESPForPlayer(targetPlayer)
    if targetPlayer == player then return end
    
    local character = targetPlayer.Character
    if not character then return end
    
    if espHighlights[targetPlayer] then
        pcall(function() espHighlights[targetPlayer]:Destroy() end)
    end
    
    local success, highlight = pcall(function()
        local newHighlight = Instance.new("Highlight")
        newHighlight.Name = "Rafa37_ESP"
        newHighlight.Adornee = character
        newHighlight.FillColor = Colors.Primary
        newHighlight.FillTransparency = Config.ESP_Transparency
        newHighlight.OutlineColor = Colors.Primary
        newHighlight.OutlineTransparency = 0.3
        newHighlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        newHighlight.Parent = character
        return newHighlight
    end)
    
    if success then espHighlights[targetPlayer] = highlight end
end

local function updateESP()
    if not States.esp then return end
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local character = otherPlayer.Character
            if character then
                if not espHighlights[otherPlayer] or not espHighlights[otherPlayer].Parent then
                    createESPForPlayer(otherPlayer)
                else
                    local highlight = espHighlights[otherPlayer]
                    if highlight then
                        highlight.FillTransparency = Config.ESP_Transparency
                        highlight.FillColor = Colors.Primary
                        highlight.OutlineColor = Colors.Primary
                    end
                end
            else
                if espHighlights[otherPlayer] then
                    pcall(function() espHighlights[otherPlayer]:Destroy() end)
                    espHighlights[otherPlayer] = nil
                end
            end
        end
    end
end

local function toggleESP(state)
    States.esp = state
    
    if Toggles.esp then
        Toggles.esp.setState(state)
    end
    
    if state then
        cleanupESP()
        for _, otherPlayer in ipairs(Players:GetPlayers()) do
            if otherPlayer ~= player then createESPForPlayer(otherPlayer) end
        end
        
        Players.PlayerAdded:Connect(function(newPlayer)
            if States.esp and newPlayer ~= player then
                newPlayer.CharacterAdded:Connect(function()
                    task.wait(0.5)
                    if States.esp then createESPForPlayer(newPlayer) end
                end)
            end
        end)
        
        Players.PlayerRemoving:Connect(function(leavingPlayer)
            if espHighlights[leavingPlayer] then
                pcall(function() espHighlights[leavingPlayer]:Destroy() end)
                espHighlights[leavingPlayer] = nil
            end
        end)
        
        if espUpdateConnection then espUpdateConnection:Disconnect() end
        espUpdateConnection = RunService.Heartbeat:Connect(updateESP)
        
        createNotification("ESP", "Ativado (E)", "success")
    else
        cleanupESP()
        if espUpdateConnection then espUpdateConnection:Disconnect() end
        createNotification("ESP", "Desativado (E)", "info")
    end
end

