local function selectTab(index)
    currentTab = index
    for i, content in ipairs(tabContents) do
        if content and content.Frame then
            content.Frame.Visible = (i == index)
            if i == index then
                task.spawn(function()
                    content.Frame.CanvasSize = UDim2.new(0, 0, 0, content.Layout.AbsoluteContentSize.Y + 20)
                end)
            end
        end
    end
    
    for i, button in ipairs(tabButtons) do
        if button then
            if i == index then
                button.BackgroundTransparency = 0
                button.TextColor3 = Colors.Primary
            else
                button.BackgroundTransparency = 0.3
                button.TextColor3 = Colors.TextSecondary
            end
        end
    end
end

for i, button in ipairs(tabButtons) do
    button.MouseButton1Click:Connect(function()
        selectTab(i)
    end)
end

