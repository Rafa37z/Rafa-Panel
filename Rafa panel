    frameCorner.Parent = frame
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -80, 0, 25)
    nameLabel.Position = UDim2.new(0, 15, 0, 10)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = name
    nameLabel.TextColor3 = Colors.Text
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 16
    nameLabel.TextScaled = false
    nameLabel.ZIndex = 16
    nameLabel.Parent = frame
    
    if hotkey then
        local hotkeyFrame = Instance.new("Frame")
        hotkeyFrame.Size = UDim2.new(0, 30, 0, 20)
        hotkeyFrame.Position = UDim2.new(0, nameLabel.TextBounds.X + 25, 0, 12)
        hotkeyFrame.BackgroundColor3 = Colors.Primary
        hotkeyFrame.BackgroundTransparency = 0.7
        hotkeyFrame.BorderSizePixel = 0
        hotkeyFrame.ZIndex = 17
        hotkeyFrame.Parent = frame
        
        local hotkeyCorner = Instance.new("UICorner")
        hotkeyCorner.CornerRadius = UDim.new(0, 4)
        hotkeyCorner.Parent = hotkeyFrame
        
        local hotkeyText = Instance.new("TextLabel")
        hotkeyText.Size = UDim2.new(1, 0, 1, 0)
        hotkeyText.BackgroundTransparency = 1
        hotkeyText.Text = hotkey
        hotkeyText.TextColor3 = Colors.Text
        hotkeyText.Font = Enum.Font.GothamBold
        hotkeyText.TextSize = 12
        hotkeyText.TextScaled = false
        hotkeyText.ZIndex = 18
        hotkeyText.Parent = hotkeyFrame
    end
    
    local descLabel = Instance.new("TextLabel")
    descLabel.Size = UDim2.new(1, -80, 0, 20)
    descLabel.Position = UDim2.new(0, 15, 0, 35)
    descLabel.BackgroundTransparency = 1
    descLabel.Text = description
    descLabel.TextColor3 = Colors.TextSecondary
    descLabel.TextXAlignment = Enum.TextXAlignment.Left
    descLabel.Font = Enum.Font.Gotham
    descLabel.TextSize = 12
    descLabel.TextScaled = false
    descLabel.ZIndex = 16
    descLabel.Parent = frame
    
    local toggleButton = Instance.new("TextButton")
    toggleButton.Size = UDim2.new(0, 60, 0, 30)
    toggleButton.Position = UDim2.new(1, -75, 0.5, -15)
    toggleButton.BackgroundColor3 = defaultValue and Colors.Primary or Colors.Danger
    toggleButton.Text = defaultValue and "ON" or "OFF"
    toggleButton.TextColor3 = Colors.Text
    toggleButton.Font = Enum.Font.GothamBold
    toggleButton.TextSize = 12
    toggleButton.TextScaled = false
    toggleButton.ZIndex = 17
    toggleButton.Parent = frame
    
    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(0, 6)
    toggleCorner.Parent = toggleButton
    
    local active = defaultValue
    
    local function updateUI()
        if active then
            toggleButton.BackgroundColor3 = Colors.Primary
            toggleButton.Text = "ON"
        else
            toggleButton.BackgroundColor3 = Colors.Danger
            toggleButton.Text = "OFF"
        end
    end
    
    if defaultValue and callback then
        task.spawn(function() callback(true) end)
    end
    
    toggleButton.MouseButton1Click:Connect(function()
        active = not active
        updateUI()
        
        if callback then
            task.spawn(function() callback(active) end)
        end
        
        task.spawn(function()
            createNotification(name, active and "ativado" or "desativado", active and "success" or "info")
        end)
    end)
    
    local function setState(state)
        if active == state then return end
        active = state
        updateUI()
    end
    
    return {frame = frame, setState = setState}
end

