--[[
    ========== AIM BOT ==========
]]
local function toggleAimbot(state)
    States.aimbot = state
    
    if Toggles.aimbot then
        Toggles.aimbot.setState(state)
    end
    
    if state then
        if aimbotConnection then aimbotConnection:Disconnect() end
        
        aimbotConnection = RunService.Heartbeat:Connect(function()
            if not States.aimbot then return end
            
            if Config.StealthMode then
                task.wait(math.random(1, 5) / 100)
            end
            
            local closestPlayer = nil
            local shortestDistance = Config.AimbotFOV
            local targetPosition = nil
            
            for _, otherPlayer in ipairs(Players:GetPlayers()) do
                if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("Head") then
                    local head = otherPlayer.Character.Head
                    local headPos = head.Position
                    local screenPos, onScreen = camera:WorldToViewportPoint(headPos)
                    
                    if onScreen then
                        local distance = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                        if distance < shortestDistance then
                            shortestDistance = distance
                            closestPlayer = otherPlayer
                            targetPosition = headPos
                        end
                    end
                end
            end
            
            if closestPlayer and targetPosition then
                if Config.HumanLikeBehavior then
                    local currentLook = camera.CFrame.LookVector
                    local targetLook = (targetPosition - camera.CFrame.Position).Unit
                    local smoothLook = currentLook:Lerp(targetLook, Config.AimbotSmoothness)
                    camera.CFrame = CFrame.new(camera.CFrame.Position, camera.CFrame.Position + smoothLook)
                else
                    camera.CFrame = CFrame.new(camera.CFrame.Position, targetPosition)
                end
            end
        end)
        
        createNotification("Aim Bot", "Ativado (K)", "success")
    else
        if aimbotConnection then
            aimbotConnection:Disconnect()
            aimbotConnection = nil
        end
        createNotification("Aim Bot", "Desativado (K)", "info")
    end
end

--[[
    ========== FLY ==========
]]
local function toggleFly(state)
    States.fly = state
    local character = player.Character
    
    if not character then 
        createNotification("Erro", "Personagem não encontrado", "error")
        return 
    end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not rootPart then 
        createNotification("Erro", "Componentes do personagem não encontrados", "error")
        return 
    end
    
    if Toggles.fly then
        Toggles.fly.setState(state)
    end
    
    if state then
        if flyConnection then flyConnection:Disconnect() end
        if flyBodyVelocity then flyBodyVelocity:Destroy() end
        if flyBodyGyro then flyBodyGyro:Destroy() end
        
        humanoid.PlatformStand = true
        humanoid.AutoRotate = true
        humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        
        flyBodyVelocity = Instance.new("BodyVelocity")
        flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        flyBodyVelocity.MaxForce = Vector3.new(5000, 5000, 5000)
        flyBodyVelocity.P = 1250
        flyBodyVelocity.Parent = rootPart
        
        flyBodyGyro = Instance.new("BodyGyro")
        flyBodyGyro.MaxTorque = Vector3.new(5000, 5000, 5000)
        flyBodyGyro.P = 1250
        flyBodyGyro.D = 500
        flyBodyGyro.CFrame = CFrame.new(rootPart.Position, rootPart.Position + camera.CFrame.LookVector)
        flyBodyGyro.Parent = rootPart
        
        flyConnection = RunService.Heartbeat:Connect(function()
            if not States.fly or not flyBodyVelocity or not character or not humanoid then return end
            
            humanoid.PlatformStand = true
            
            if flyBodyGyro and flyBodyGyro.Parent then
                flyBodyGyro.CFrame = CFrame.new(rootPart.Position, rootPart.Position + camera.CFrame.LookVector)
            end
            
            local moveDirection = Vector3.new()
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                moveDirection = moveDirection + camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                moveDirection = moveDirection - camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                moveDirection = moveDirection - camera.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                moveDirection = moveDirection + camera.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                moveDirection = moveDirection + Vector3.new(0, 1, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                moveDirection = moveDirection + Vector3.new(0, -1, 0)
            end
            
            if moveDirection.Magnitude > 0 then
                moveDirection = moveDirection.Unit * Config.FlySpeed
            end
            
            flyBodyVelocity.Velocity = moveDirection
        end)
        
        createNotification("Fly", "Ativado (J)", "success")
        
    else
        if flyBodyVelocity then flyBodyVelocity:Destroy() end
        if flyBodyGyro then flyBodyGyro:Destroy() end
        if flyConnection then flyConnection:Disconnect() end
        
        if humanoid then
            humanoid.PlatformStand = false
            humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
        end
        
        createNotification("Fly", "Desativado (J)", "info")
    end
end

