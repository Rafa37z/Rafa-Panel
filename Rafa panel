local function updatePlayerList()
    for _, child in ipairs(playerListFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name ~= "UIListLayout" then
            child:Destroy()
        end
    end
    
    viewButtons = {}
    local searchText = searchBox.Text:lower()
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local playerName = otherPlayer.Name:lower()
            
            if searchText == "" or playerName:find(searchText) then
                local playerFrame = Instance.new("Frame")
                playerFrame.Size = UDim2.new(1, 0, 0, 50)
                playerFrame.BackgroundColor3 = Colors.Surface
                playerFrame.BackgroundTransparency = 0.1
                playerFrame.BorderSizePixel = 0
                playerFrame.Parent = playerListFrame
                
                local playerCorner = Instance.new("UICorner")
                playerCorner.CornerRadius = UDim.new(0, 6)
                playerCorner.Parent = playerFrame
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -130, 1, 0)
                nameLabel.Position = UDim2.new(0, 10, 0, 0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = otherPlayer.Name
                nameLabel.TextColor3 = Colors.Text
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Font = Enum.Font.GothamBold
                nameLabel.TextSize = 14
                nameLabel.ZIndex = 18
                nameLabel.Parent = playerFrame
                
                local viewButton = Instance.new("TextButton")
                viewButton.Size = UDim2.new(0, 50, 0, 30)
                viewButton.Position = UDim2.new(1, -115, 0.5, -15)
                viewButton.BackgroundColor3 = Colors.ViewColor
                viewButton.Text = "VIEW"
                viewButton.TextColor3 = Colors.Text
                viewButton.Font = Enum.Font.GothamBold
                viewButton.TextSize = 10
                viewButton.ZIndex = 19
                viewButton.Parent = playerFrame
                
                if viewTarget == otherPlayer then
                    viewButton.BackgroundColor3 = Colors.ViewActiveColor
                end
                
                local viewCorner = Instance.new("UICorner")
                viewCorner.CornerRadius = UDim.new(0, 6)
                viewCorner.Parent = viewButton
                
                viewButton.MouseButton1Click:Connect(function()
                    viewPlayer(otherPlayer)
                end)
                
                table.insert(viewButtons, viewButton)
                
                local tpButton = Instance.new("TextButton")
                tpButton.Size = UDim2.new(0, 50, 0, 30)
                tpButton.Position = UDim2.new(1, -60, 0.5, -15)
                tpButton.BackgroundColor3 = Colors.Primary
                tpButton.Text = "TP"
                tpButton.TextColor3 = Colors.Text
                tpButton.Font = Enum.Font.GothamBold
                tpButton.TextSize = 12
                tpButton.ZIndex = 19
                tpButton.Parent = playerFrame
                
                local tpCorner = Instance.new("UICorner")
                tpCorner.CornerRadius = UDim.new(0, 6)
                tpCorner.Parent = tpButton
                
                tpButton.MouseButton1Click:Connect(function()
                    teleportToPlayer(otherPlayer)
                end)
            end
        end
    end
end

searchBox.Changed:Connect(function(property)
