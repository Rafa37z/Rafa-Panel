    ========== VIEW ==========
]]
local viewTarget = nil

local function endViewMode()
    if viewConnection then
        viewConnection:Disconnect()
        viewConnection = nil
    end
    if viewMouseConnection then
        viewMouseConnection:Disconnect()
        viewMouseConnection = nil
    end
    if viewWheelConnection then
        viewWheelConnection:Disconnect()
        viewWheelConnection = nil
    end
    if viewESCConnection then
        viewESCConnection:Disconnect()
        viewESCConnection = nil
    end
    
    camera.CameraType = Enum.CameraType.Custom
    
    for _, btn in ipairs(viewButtons) do
        if btn and btn.Parent then
            btn.BackgroundColor3 = Colors.ViewColor
        end
    end
    
    viewTarget = nil
    createNotification("View", "Visualização encerrada", "info")
end

local function viewPlayer(targetPlayer)
    if viewConnection then
        if viewTarget == targetPlayer then
            endViewMode()
            return
        else
            endViewMode()
            task.wait(0.1)
        end
    end
    
    if not targetPlayer or targetPlayer == player then
        createNotification("View", "Selecione um jogador válido", "error")
        return
    end
    
    local targetChar = targetPlayer.Character
    if not targetChar then
        createNotification("View", "Jogador sem personagem", "error")
        return
    end
    
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetRoot then
        createNotification("View", "Não foi possível visualizar", "error")
        return
    end
    
    camera.CameraType = Enum.CameraType.Scriptable
    
    local camDistance = 10
    local camHeight = 3
    local camAngle = 0
    local mouseSensitivity = 0.005
    local zoomSpeed = 2
    
    local function updateCamera()
        if not targetChar or not targetRoot or not targetRoot.Parent then
            endViewMode()
            return
        end
        
        local offset = Vector3.new(
            math.sin(camAngle) * camDistance,
            camHeight,
            math.cos(camAngle) * camDistance
        )
        
        camera.CFrame = CFrame.new(targetRoot.Position + offset, targetRoot.Position + Vector3.new(0, 2, 0))
    end
    
    viewMouseConnection = UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and viewConnection then
            local delta = input.Delta
            camAngle = camAngle + delta.X * mouseSensitivity
            camHeight = math.clamp(camHeight - delta.Y * mouseSensitivity * 10, 1, 8)
            updateCamera()
        end
    end)
    
    viewWheelConnection = UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseWheel and viewConnection then
            camDistance = math.clamp(camDistance - input.Position.Z * zoomSpeed, 3, 30)
            updateCamera()
        end
    end)
    
    viewESCConnection = UserInputService.InputBegan:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.Escape and viewConnection then
            endViewMode()
        end
    end)
    
    viewConnection = RunService.Heartbeat:Connect(updateCamera)
    viewTarget = targetPlayer
    
    for _, btn in ipairs(viewButtons) do
        if btn and btn.Parent then
            local parentFrame = btn.Parent
            if parentFrame and parentFrame:FindFirstChild("TextLabel") then
                local nameLabel = parentFrame:FindFirstChild("TextLabel")
                if nameLabel and nameLabel.Text == targetPlayer.Name then
                    btn.BackgroundColor3 = Colors.ViewActiveColor
                else
                    btn.BackgroundColor3 = Colors.ViewColor
                end
            end
        end
    end
    
    createNotification("View", "Visualizando " .. targetPlayer.Name .. " - ESC para sair", "info")
end

